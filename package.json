{
	"name": "inkstream",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"vision:ping": "node ./node_modules/tsx/dist/cli.mjs scripts/vision-ping.ts",
		"map:ping": "node ./node_modules/tsx/dist/cli.mjs scripts/map-route-ping.ts",
		"image:ping": "node ./node_modules/tsx/dist/cli.mjs scripts/image-gen-ping.ts",
		"piston:ping": "node ./node_modules/tsx/dist/cli.mjs scripts/piston-ping.ts",
		"telegram:sync-webhook": "node ./node_modules/tsx/dist/cli.mjs scripts/telegram-sync-webhook.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/leaflet": "^1.9.21",
		"drizzle-kit": "^0.30.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.0.0",
		"vite": "^5.0.0"
	},
	"dependencies": {
		"@elevenlabs/client": "^1.7.1",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.40.0",
		"highlight.js": "^11.11.1",
		"leaflet": "^1.9.4",
		"marked": "^18.0.3",
		"mysql2": "^3.12.0",
		"zod": "^3.24.0"
	}
}
