# Inkstream — copy to .env and fill in values (never commit .env)

# --- Database (use DATABASE_URL or discrete MYSQL_* vars) ---
# DATABASE_URL=mysql://user:password@host:3306/ai_platform
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=ai_platform

# --- App ---
SESSION_SECRET=change-me-in-production
TELEGRAM_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-secret
TELEGRAM_WEBHOOK_BASE_URL=https://your-domain.com
TELEGRAM_WEBHOOK_ROUTE_SECRET=

# --- OpenRouter (required) ---
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_DEFAULT_MODEL=qwen/qwen3.5-flash-02-23

# --- Vision relay (optional; summarizes images for non-vision models) ---
VISION_RELAY_ENABLED=true
VISION_RELAY_MODEL=google/gemini-2.0-flash-001
VISION_RELAY_MAX_TOKENS=512

# --- Chat titles (optional) ---
CHAT_TITLE_ENABLED=true
CHAT_TITLE_MODEL=google/gemini-2.0-flash-lite-001

# --- Rolling chat summaries (optional; LLM context only, full history kept in UI) ---
CHAT_SUMMARY_ENABLED=true
CHAT_SUMMARY_MODEL=google/gemini-2.0-flash-lite-001
# CHAT_SUMMARY_INTERVAL=15
# CHAT_SUMMARY_HOT_TAIL=20
# CHAT_SUMMARY_MAX_TOKENS=512
# CHAT_SUMMARY_BACKFILL_MIN=100

# --- Auto model routing (dashboard) ---
# Tiny classifier per message; run npm run router:benchmark to compare candidates
OPENROUTER_ROUTER_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1-0528

# --- Web search (optional; empty disables web_search / image_search tools) ---
# Get a key at https://api.search.brave.com
BRAVE_SEARCH_API_KEY=
# BRAVE_SEARCH_MAX_RESULTS=20
# BRAVE_SEARCH_MAX_OUTPUT_CHARS=28000
# BRAVE_SEARCH_EXTRA_SNIPPETS=true
# BRAVE_SEARCH_IMAGE_MAX_RESULTS=16
# BRAVE_SEARCH_COUNTRY=US
# BRAVE_SEARCH_LANG=en

# --- fetch_url tool (optional) ---
# FETCH_URL_MAX_CHARS=12000
# FETCH_URL_MAX_PAGE_CHARS=200000

# --- Map route tool (optional; defaults are public OSM endpoints) ---
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSRM_BASE_URL=https://router.project-osrm.org
MAP_HTTP_USER_AGENT=Inkstream/1.0

# --- Voice mode (optional; empty disables dashboard voice) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# --- Image generation tool (optional) ---
OPENROUTER_IMAGE_GEN_ENABLED=true
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# --- Python sandbox / execute_python tool (optional; empty disables tool) ---
PISTON_URL=https://piston.paredes.cloud
PISTON_PYTHON_VERSION=3.12.0
PISTON_RUN_TIMEOUT_MS=30000
PISTON_MAX_OUTPUT_CHARS=32768
